# Environment Variables

# API Base URL
# Using relative path for Vite proxy (development) and Nginx proxy (production)
VITE_API_BASE_URL=/api/v1

# Examples:
# Direct backend connection (may require CORS configuration):
# VITE_API_BASE_URL=http://localhost:8080/api/v1

# Production API:
# VITE_API_BASE_URL=https://api.aitestos.com/api/v1
