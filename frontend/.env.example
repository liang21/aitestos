# Environment Variables

# API Base URL
# Default: /api/v1
# All HTTP requests will be prefixed with this value
VITE_API_BASE_URL=/api/v1

# Examples:
# Local development with backend on port 8080:
# VITE_API_BASE_URL=http://localhost:8080/api/v1

# Production API:
# VITE_API_BASE_URL=https://api.aitestos.com/api/v1
