# ============================================================
# aitestos Docker Compose Environment Configuration
# Copy this file to .env and update values before running:
#   cp .env.example .env
# ============================================================

# ---- Application ----
APP_PORT=8080
LOG_LEVEL=info
LOG_JSON=true

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aitestos
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379

# ---- MinIO ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- Milvus ----
MILVUS_PORT=19530

# ---- RabbitMQ ----
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ---- DeepSeek LLM (required) ----
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
LLM_BASE_URL=https://api.deepseek.com

# ---- JWT (required, min 8 chars) ----
JWT_SECRET=changeme_jwt_secret_min_8_chars
